 def _cleanup_invalid_pid_path(pid_path: Path, *, cleanup_stale: bool) -> None:
     if not cleanup_stale:
         return
+    # The caller has already proven this PID record is invalid/stale
+    # (missing process, start_time mismatch, wrong kind, unparseable).
+    # Unlink directly instead of routing through remove_pid_file(), which
+    # refuses to delete files whose recorded PID differs from os.getpid()
+    # and therefore leaves stale records in place — causing the next
+    # `gateway run --replace` to lose its O_CREAT|O_EXCL race and exit
+    # with "PID file race lost to another gateway instance".
     try:
-        if pid_path == _get_pid_path():
-            remove_pid_file()
-        else:
-            pid_path.unlink(missing_ok=True)
+        pid_path.unlink(missing_ok=True)
     except Exception:
         pass
 
