+class SubagentProgressAgent:
+    """Agent that relays delegate_task child progress through the gateway callback."""
+
+    def __init__(self, **kwargs):
+        self.tool_progress_callback = kwargs.get("tool_progress_callback")
+        self.tools = []
+
+    def run_conversation(self, message, conversation_history=None, task_id=None):
+        self.tool_progress_callback("tool.started", "delegate_task", "inspect repo", {"goal": "inspect repo"})
+        time.sleep(0.2)
+        self.tool_progress_callback(
+            "subagent_progress",
+            "🔀 skill_view, terminal, git status --short --branch",
+        )
+        time.sleep(0.2)
+        return {
+            "final_response": "done",
+            "messages": [],
+            "api_calls": 1,
+        }
