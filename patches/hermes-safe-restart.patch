+    @classmethod
+    def _peek_pending_restart_handoff(
+        cls,
+        source: Any,
+        session_key: str,
+    ) -> tuple[List[Dict[str, Any]], Optional[Path]]:
+        """Return one-shot prefill messages staged for the next new session."""
+        path = cls._pending_restart_handoff_path
+        if not path.exists():
+            return [], None
+
+        try:
+            payload = json.loads(path.read_text(encoding="utf-8"))
+        except Exception as e:
+            logger.warning(
+                "Failed to parse pending restart handoff from %s: %s", path, e
+            )
+            return [], None
+
+        if not isinstance(payload, dict):
+            logger.warning("Pending restart handoff must be a JSON object: %s", path)
+            return [], None
+
+        target = payload.get("target") or {}
+        if not isinstance(target, dict):
+            logger.warning(
+                "Pending restart handoff target must be a JSON object: %s", path
+            )
+            return [], None
+
+        source_platform = getattr(getattr(source, "platform", None), "value", None)
+        if source_platform is None:
+            source_platform = str(getattr(source, "platform", "") or "")
+        source_platform = str(source_platform or "")
+        source_user_id = str(getattr(source, "user_id", "") or "")
+        source_chat_id = str(getattr(source, "chat_id", "") or "")
+
+        target_platform = str(target.get("platform", "") or "")
+        target_user_id = str(target.get("user_id", "") or "")
+        target_chat_id = str(target.get("chat_id", "") or "")
+        target_session_key = str(target.get("session_key", "") or "")
+
+        if target_platform and target_platform != source_platform:
+            return [], None
+        if target_user_id and target_user_id != source_user_id:
+            return [], None
+        if target_chat_id and target_chat_id != source_chat_id:
+            return [], None
+        if target_session_key and target_session_key != session_key:
+            return [], None
+
+        prefill_messages = payload.get("prefill_messages")
+        if isinstance(prefill_messages, list):
+            normalized: List[Dict[str, Any]] = []
+            for item in prefill_messages:
+                if not isinstance(item, dict):
+                    logger.warning(
+                        "Ignoring malformed pending restart handoff message in %s", path
+                    )
+                    return [], None
+                role = str(item.get("role", "") or "").strip()
+                content = item.get("content", "")
+                if role not in {
+                    "system",
+                    "user",
+                    "assistant",
+                    "developer",
+                } or not isinstance(content, str):
+                    logger.warning(
+                        "Ignoring malformed pending restart handoff message in %s", path
+                    )
+                    return [], None
+                normalized.append({"role": role, "content": content})
+            if normalized:
+                return normalized, path
+
+        summary = str(payload.get("summary", "") or "").strip()
+        if not summary:
+            logger.warning(
+                "Pending restart handoff in %s has no usable summary/prefill_messages",
+                path,
+            )
+            return [], None
+
+        return (
+            [
+                {
+                    "role": "user",
+                    "content": (
+                        "[Restart handoff context — written before gateway restart]\n"
+                        f"{summary}"
+                    ),
+                }
+            ],
+            path,
+        )
+
+    @staticmethod
+    def _consume_pending_restart_handoff(path: Optional[Path]) -> None:
+        """Archive a consumed one-shot restart handoff file."""
+        if path is None or not path.exists():
+            return
+        try:
+            consumed_dir = path.parent / "consumed"
+            consumed_dir.mkdir(parents=True, exist_ok=True)
+            timestamp = datetime.utcnow().strftime("%Y%m%dT%H%M%SZ")
+            archived_path = consumed_dir / f"{path.stem}.{timestamp}{path.suffix}"
+            path.replace(archived_path)
+            logger.info("Consumed pending restart handoff: %s", archived_path)
+        except Exception as e:
+            logger.warning("Failed to archive pending restart handoff %s: %s", path, e)
